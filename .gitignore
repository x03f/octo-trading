# --- Озеро данных: 316 монет × 5 ТФ × 2 года ≈ 1.4 ГБ parquet. В git не место. ---
data/
*.parquet
manifest.json

# --- Логи и мусор ---
*.log
logs/
__pycache__/
*.pyc
*.pyo

# --- ЛОКАЛЬНЫЕ СЕКРЕТЫ (никогда не коммитить) ---
# Реальные адреса панелей: поддомены намеренно неугадываемые, это часть защиты.
*.local.json
endpoints.local.json
.env
*.key
*_deploy

# --- Крупные бинарные результаты (кривые эквити); .json-метрики оставляем ---
results/*.npy

# --- Node (playwright-харнесс ставится локально) ---
node_modules/
package-lock.json
nautilus-venv/

# --- Nautilus Trading Lab: локальное состояние (не в git) ---
nautilus-lab/var/
nautilus-lab/**/__pycache__/
nautilus-lab/web/data/adaptive_state.json
nautilus-lab/web/data/paper_s11_status.json
